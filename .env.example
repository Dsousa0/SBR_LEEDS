# ===========================================
# PROSPEC LEADS - Variáveis de Ambiente
# ===========================================
# Copie este arquivo para .env e preencha os valores
# NUNCA commite o arquivo .env no Git

# Ambiente (development | production)
APP_ENV=development

# PostgreSQL
POSTGRES_USER=prospec
POSTGRES_PASSWORD=altere_esta_senha_local
POSTGRES_DB=prospec_db

# pgAdmin (interface web do banco em http://localhost:5050)
[email protected]
PGADMIN_PASSWORD=altere_esta_senha_pgadmin

# Configurações da aplicação (futuras etapas)
# LOG_LEVEL=INFO
# DEFAULT_PAGE_SIZE=50

# ===========================================
# ETL — scripts etl/ (Etapa 2)
# ===========================================
# Os scripts ETL usam DATABASE_URL acima quando rodando via Docker (serviço etl).
# Para rodar fora do Docker (host), ajuste o host para localhost:
# ETL_DATABASE_URL=postgresql://prospec:altere_esta_senha_local@localhost:5432/prospec_db
